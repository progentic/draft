# -----------------------------------------------------------------------------
# DRAFT repository ignore rules
# Rust + Tauri 2 + TypeScript/React/Tiptap + Python helper workers + Bash tooling
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
/target/
**/target/
/debug/
/release/

# Rust formatter backups
**/*.rs.bk

# MSVC Windows debug symbols
*.pdb

# Cargo mutation testing output
**/mutants.out*/

# Keep Cargo.lock for applications.
# Do not ignore Cargo.lock in this repository.

# -----------------------------------------------------------------------------
# Tauri
# -----------------------------------------------------------------------------
/src-tauri/target/
/src-tauri/gen/
/src-tauri/.tauri/
/src-tauri/icons/icon.icns
/src-tauri/icons/icon.ico
/src-tauri/icons/*.png

# Tauri build output may contain signed/bundled application artifacts.
/src-tauri/target/*/bundle/
/src-tauri/target/*/release/bundle/

# Local Tauri signing and platform secrets.
*.key
*.keystore
*.jks
*.p12
*.mobileprovision
*.provisionprofile

# -----------------------------------------------------------------------------
# Node / TypeScript / React / Tiptap
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Package-manager caches
.pnpm-store/
.yarn/
!.yarn/releases/
!.yarn/plugins/
!.yarn/sdks/
!.yarn/versions/

# Frontend build output
/dist/
/build/
/.vite/
.vite/
coverage/
.nyc_output/

# TypeScript incremental cache
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Python helper workers
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/

# Virtual environments
.venv/
venv/
env/
ENV/

# Python package/build artifacts
*.egg-info/
.eggs/
build/
dist/
site/

# -----------------------------------------------------------------------------
# Local environment and secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample

# Local config that may contain machine-specific paths or credentials.
*.local
*.local.*
config.local.*
secrets.*

# Local agent instructions are machine/workspace-specific.
/AGENTS.md

# Generated credentials / tokens / certificates
*.pem
*.crt
*.cer
*.der
*.pfx
*.asc
*.gpg
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# -----------------------------------------------------------------------------
# Databases, document working files, and generated exports
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*.bak
*.tmp
*.temp
*.swp
*.swo

# Generated document/export artifacts. Keep source fixtures in tests explicitly.
*.docx
*.pdf
*.odt
*.rtf
*.html
*.epub

# Allow committed test fixtures when intentionally added.
!tests/fixtures/**/*.docx
!tests/fixtures/**/*.pdf
!src-tauri/tests/fixtures/**/*.docx
!src-tauri/tests/fixtures/**/*.pdf

# -----------------------------------------------------------------------------
# Logs and local runtime output
# -----------------------------------------------------------------------------
logs/
*.log
*.trace
*.prof
*.pid
*.seed

# Local scratch/output folders
.tmp/
tmp/
temp/
out/
artifacts/

# -----------------------------------------------------------------------------
# Editors and IDEs
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# RustRover / JetBrains
# JetBrains maintains a broader template at:
# https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
# Uncomment the next line only if the repository should ignore all JetBrains project files.
#.idea/

# Vim / Emacs
*~
*.un~
\#*\#
.\#*

# -----------------------------------------------------------------------------
# Operating system files
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# GitHub Actions / local verification caches
# -----------------------------------------------------------------------------
.cache/
.local-cache/

# Keep workflow definitions tracked.
!.github/
!.github/workflows/
